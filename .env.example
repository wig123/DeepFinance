# DeepFinance 环境配置示例
# 复制此文件为 .env 并填入真实的 API keys

# ===== LLM 配置 =====
# LLM 提供商: anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic API (推荐使用 Claude Sonnet 4)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (可选)
OPENAI_API_KEY=your_openai_api_key_here

# 各 Agent 使用的模型
EDITOR_MODEL=claude-sonnet-4-20250514
RESEARCHER_MODEL=claude-sonnet-4-20250514
WRITER_MODEL=claude-sonnet-4-20250514
REVIEWER_MODEL=claude-sonnet-4-20250514


# ===== 搜索引擎配置 =====
# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

# Serper Search API (可选)
SERPER_API_KEY=your_serper_api_key_here


# ===== 金融数据配置 =====
# AKShare: 免费，无需 API key
# efinance: 免费，无需 API key
# yfinance: 免费，无需 API key

# 如需使用其他金融数据源（如 Alpha Vantage, Financial Modeling Prep）
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# FMP_API_KEY=your_fmp_key_here


# ===== 其他配置 =====
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 输出目录
OUTPUT_DIR=outputs

# 缓存目录
CACHE_DIR=.cache

# 图表分析提示词文件路径（可选；不配置则跳过深度图表分析）
# CHART_PROMPT_PATH=

# 端到端测试默认 PDF（可选；亦可作为 scripts/run_pipeline.py 的位置参数传入）
# PIPELINE_TEST_PDF=inputs/sample.pdf

# 调试日志路径（可选；默认 <项目根>/.cursor/debug.log）
# DEBUG_LOG_PATH=
